// Portfolio Modal 1
#portfolioModal1.portfolio-modal.modal.fade(tabindex='-1', aria-labelledby='portfolioModal1', aria-hidden='true')
    .modal-dialog.modal-xl
        .modal-content
            .modal-header.border-0
                button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
            .modal-body.text-center.pb-5
                .container
                    .row.justify-content-center
                        .col-lg-8
                            // Portfolio Modal - Title
                            h2.portfolio-modal-title.text-secondary.text-uppercase.mb-0 Teh 1
                            // Icon Divider
                            .divider-custom
                                .divider-custom-line
                                .divider-custom-icon
                                    i.fas.fa-star
                                .divider-custom-line
                            // Portfolio Modal - Image
                            img.img-fluid.rounded.mb-5(src='assets/img/portfolio/cabin.png', alt='...')
                            // Portfolio Modal - Text
                            p.mb-4
                                | Kirjoitin funktion, joka tarkistaa onko sana palindromi. Ohjelma ottaa syötteen prompt-komennolla, kääntää sanan for-silmukalla ja vertaa alkuperäiseen.
                                | Opin välittämään parametreja funktioille ja käsittelemään merkkijonoja silmukan avulla. Jos tekisin nyt uudestaan, lisäisin tarkistuksen tyhjälle syötteelle ja kirjainkoosta riippumattomuuden.\
                            a.btn.btn-primary(href='https://github.com/raemon131/web-ohjelmointi-kurssi/blob/main/kt1.js', target='_blank')
                                i.fas.fa-link.fa-fw
                                | View Project
                            button.btn.btn-primary(data-bs-dismiss='modal')
                                i.fas.fa-xmark.fa-fw
                                | Close Window